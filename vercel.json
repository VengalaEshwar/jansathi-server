{
  "version": 2,
  "builds": [
    {
      "src": "index.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "index.js"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/check-reminders",
      "schedule": "* * * * *"
    },
    {
      "path": "/api/cron/cleanup-reminders", 
      "schedule": "0 0 * * *"
    }
  ]
}